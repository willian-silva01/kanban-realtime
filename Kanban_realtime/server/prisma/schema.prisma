// =============================================
// Prisma Schema — Kanban Realtime
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User ─────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  emailMentions    Boolean @default(true) @map("email_mentions")
  emailAssigned    Boolean @default(true) @map("email_assigned")
  emailDueDate     Boolean @default(true) @map("email_due_date")
  emailBoardInvite Boolean @default(true) @map("email_board_invite")

  // Relacionamentos
  ownedBoards      Board[]           @relation("BoardOwner")
  boardMembers     BoardMember[]
  createdCards     Card[]            @relation("CardCreator")
  activityLogs     ActivityLog[]
  comments         Comment[]
  notifications    Notification[]    @relation("UserNotifications")
  cardAssignments  CardAssignee[]    @relation("CardAssigneeUser")
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
  emailLogs        EmailLog[]
  commentReactions CommentReaction[]

  @@map("users")
}

// ── Workspace ─────────────────────────────────
model Workspace {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  boards  Board[]

  @@index([ownerId])
  @@map("workspaces")
}

// ── WorkspaceMember ───────────────────────────
model WorkspaceMember {
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(member)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  owner
  admin
  member
}

// ── Board ────────────────────────────────────
model Board {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  ownerId     String   @map("owner_id")
  workspaceId String?  @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relacionamentos
  owner         User          @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workspace     Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  members       BoardMember[]
  columns       Column[]
  activityLogs  ActivityLog[]
  labels        Label[]

  @@index([ownerId])
  @@index([workspaceId])
  @@map("boards")
}

// ── BoardMember ──────────────────────────────
model BoardMember {
  id       String   @id @default(uuid())
  boardId  String   @map("board_id")
  userId   String   @map("user_id")
  role     Role     @default(editor)
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relacionamentos
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Um usuário não pode ser membro duplicado do mesmo board
  // Isso já gera um índice B-tree único para (boardId, userId) silenciosamente
  @@unique([boardId, userId])

  // Performance inversa (lookup do Painel do Usuário: "Quais boards eu pertenço?")
  @@index([userId])
  @@map("board_members")
}

enum Role {
  admin
  editor
  viewer
}

// ── Column ───────────────────────────────────
model Column {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  name      String   @db.VarChar(50)
  position  Int
  createdAt DateTime @default(now()) @map("created_at")

  // Relacionamentos
  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  // Índice composto: Filtragem por board E Ordenação por posição imediata
  @@index([boardId, position])
  @@map("columns")
}

// ── Card ─────────────────────────────────────
model Card {
  id          String   @id @default(uuid())
  columnId    String   @map("column_id")
  title       String   @db.VarChar(200)
  description String?  @db.Text
  position    Int
  createdBy   String    @map("created_by")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relacionamentos
  column     Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)
  creator    User          @relation("CardCreator", fields: [createdBy], references: [id])
  comments   Comment[]
  labels     CardLabel[]
  assignees  CardAssignee[]
  checklists Checklist[]

  // Índice composto para buscar os cartões da coluna + ordenação rápida da renderização
  @@index([columnId, position])
  @@map("cards")
}

// ── ActivityLog ──────────────────────────────
model ActivityLog {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  userId    String   @map("user_id")
  action    String   @db.VarChar(50)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  // Relacionamentos
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  // Ordenação descendente frequente no Timeline de Atividades
  @@index([boardId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// ── Comment ──────────────────────────────────
model Comment {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  card      Card               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions CommentReaction[]

  // Isolamento do carregamento da aba lateral e ordenação temporal
  @@index([cardId, createdAt(sort: Desc)])
  @@map("comments")
}

// ── CommentReaction ───────────────────────────
model CommentReaction {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
  @@map("comment_reactions")
}

// ── Label ────────────────────────────────────
model Label {
  id        String   @id @default(uuid())
  boardId   String   @map("board_id")
  name      String   @db.VarChar(50)
  color     String   @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
  @@map("labels")
}

// ── CardAssignee ─────────────────────────────
model CardAssignee {
  cardId     String   @map("card_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation("CardAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@index([userId])
  @@map("card_assignees")
}

// ── CardLabel ─────────────────────────────────
model CardLabel {
  cardId  String @map("card_id")
  labelId String @map("label_id")

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

// ── Checklist ────────────────────────────────
model Checklist {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  title     String   @db.VarChar(100)
  position  Int
  createdAt DateTime @default(now()) @map("created_at")

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([cardId, position])
  @@map("checklists")
}

// ── ChecklistItem ─────────────────────────────
model ChecklistItem {
  id          String   @id @default(uuid())
  checklistId String   @map("checklist_id")
  text        String   @db.VarChar(500)
  completed   Boolean  @default(false)
  position    Int
  completedBy String?  @map("completed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, position])
  @@map("checklist_items")
}

// ── EmailLog ──────────────────────────────────
model EmailLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventType String   @map("event_type") @db.VarChar(50)
  entityId  String   @map("entity_id") @db.VarChar(36)
  sentAt    DateTime @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, entityId, sentAt(sort: Desc)])
  @@map("email_logs")
}

// ── Notification ─────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(50)
  entityId  String?  @map("entity_id")
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  // Filtro pesadíssimo do Header: "Buscar Minhas (userId) Não Lidas (read) nas mais recentes (createdAt)"
  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}
